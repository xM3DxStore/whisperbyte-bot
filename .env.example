# Discord Bot Token (Required)
DISCORD_BOT_TOKEN=your_bot_token_here

# Bot Client ID (Required for slash command deployment)
DISCORD_CLIENT_ID=your_client_id_here

# Database Path (Optional - defaults to ./data/guardian.db)
DATABASE_PATH=./data/guardian.db

# Log Level (Optional - defaults to info)
LOG_LEVEL=info

# Owner Discord User ID (Required for owner-only commands)
OWNER_USER_ID=1485974585139531829

# Default Prefix (Optional - defaults to !)
DEFAULT_PREFIX=/

# AI Spam Detection Sensitivity (0.0 - 1.0, Default: 0.6)
SPAM_SENSITIVITY=0.6

# XP Rate Multiplier (Default: 1.0)
XP_RATE_MULTIPLIER=1.0

# Max Tickets Per User (Default: 5)
MAX_TICKETS_PER_USER=5

# Anti-Raid Join Threshold (joins per 10 seconds, Default: 5)
ANTI_RAID_JOIN_THRESHOLD=5

# Appeal Server Invite (Optional)
APPEAL_SERVER_INVITE=discord.gg/HEVQ7fzBKs
